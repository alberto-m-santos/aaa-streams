# Postgres password for the Zilean database
POSTGRES_PASSWORD=change-me-long-random-string

# Prowlarr API key (Prowlarr UI -> Settings -> General -> API Key)
# Leave blank on first boot, fill after Prowlarr is configured, then restart comet.
PROWLARR_API_KEY=

# Comet dashboard admin password (also used as the debrid stream proxy password)
COMET_ADMIN_PASSWORD=change-me

# Comet public API token used in the /s/<token>/ Stremio URL prefix.
# Persisting this here keeps existing manifest URLs working across container recreates.
# Generate with: openssl rand -hex 24
# Rotate this value to invalidate all existing friend manifest URLs in one shot.
COMET_PUBLIC_API_TOKEN=

# Cloudflare Tunnel token (Zero Trust dashboard -> Networks -> Tunnels -> Create)
CLOUDFLARE_TUNNEL_TOKEN=

# Real-Debrid API key used as the server-side default when PROXY_DEBRID_STREAM=True.
# Friends using the instance through the proxy will stream via this account without
# needing their own RD subscription. Get it from https://real-debrid.com/apitoken
REALDEBRID_API_KEY=
